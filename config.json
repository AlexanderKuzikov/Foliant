{
  "workDir": "C:/tasks",
  "logDir": "C:/tasks/logs",
  "outputFilePrefix": "",
  "deleteSourcePdfs": false,
  "maxPagesPerDocument": 19,
  "margins": {
    "top": 15,
    "right": 10,
    "bottom": 15,
    "left": 10
  },
  "layout": {
    "single": {
      "pagesPerSheet": 1,
      "cols": 1,
      "rows": 1,
      "orientation": "portrait",
      "rasterDpi": 300,
      "jpegQuality": 75
    },
    "twoPerSheet": {
      "pagesPerSheet": 2,
      "cols": 1,
      "rows": 2,
      "orientation": "portrait",
      "rotateContent": 90,
      "rasterDpi": 200,
      "jpegQuality": 75
    },
    "fourPerSheet": {
      "pagesPerSheet": 4,
      "cols": 2,
      "rows": 2,
      "orientation": "portrait",
      "rasterDpi": 150,
      "jpegQuality": 75
    }
  }
}