{
  "workDir": "C:/tasks",
  "logDir": "C:/tasks/logs",
  "outputFilePrefix": "fol_",
  "deleteSourcePdfs": false,
  "maxPagesPerDocument": 19,
  "margins": {
    "top": 15,
    "right": 10,
    "bottom": 15,
    "left": 10
  },
  "layout": {
    "single": {
      "pagesPerSheet": 1,
      "cols": 1,
      "rows": 1,
      "orientation": "portrait",
      "rasterDpi": 250,
      "jpegQuality": 80
    },
    "twoPerSheet": {
      "pagesPerSheet": 2,
      "cols": 2,
      "rows": 1,
      "orientation": "landscape",
      "rasterDpi": 180,
      "jpegQuality": 60
    },
    "fourPerSheet": {
      "pagesPerSheet": 4,
      "cols": 2,
      "rows": 2,
      "orientation": "portrait",
      "rasterDpi": 120,
      "jpegQuality": 50
    }
  }
}
